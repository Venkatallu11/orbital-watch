__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# state.json, watchlist.json, and digest.md are intentionally NOT ignored:
# the scheduled GitHub Actions workflow (.github/workflows/orbital-watch.yml)
# commits them back to the repo so state persists between ephemeral runs.
# If you want a private local watchlist instead, use a different filename
# (e.g. my-watchlist.json) and pass it to --watchlist directly -- it won't
# be picked up by the scheduled workflow, which looks for watchlist.json.

# docs/data.json is generated fresh every run (see site_data_cli.py) and
# deployed straight to GitHub Pages as a build artifact -- it's not
# committed to git history to avoid an hourly commit on every run.
docs/data.json
